# ── Taskflow environment variables ─────────────────────────────────────────────
#
# Copy this file to .env before running docker compose up.
# Never commit your actual .env file.

# Port the Vite dev server is exposed on the host.
APP_PORT=5173

# Base URL that the React app uses for all API requests.
# MSW intercepts all requests to this origin in the browser — no real server needed.
VITE_API_BASE_URL=http://localhost:4000
